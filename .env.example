# Tomino — variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs

# ── IA (xAI / Grok) ────────────────────────────────────────
# Obtenez votre clé sur https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# ── Paiement (Stripe) ──────────────────────────────────────
# Clés disponibles sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email transactionnel (Resend) ──────────────────────────
# Obtenez votre clé sur https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Flask ──────────────────────────────────────────────────
# Chaîne aléatoire longue pour signer les sessions
FLASK_SECRET_KEY=generate-a-random-string-here

# ── Répartition géographique / sectorielle (Financial Modeling Prep) ──
# Gratuit sur https://financialmodelingprep.com/ (250 req/jour)
# Utilisé uniquement pour la page Répartition (sector + country des actions)
FMP_API_KEY=your_fmp_api_key_here

# ── Synchronisation cloud (optionnel) ──────────────────────
# URL de votre instance de sync si vous la self-hostez
# SYNC_SERVER_URL=https://sync.votre-domaine.com
